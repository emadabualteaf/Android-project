<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="#F4F6F9">

    <TextView
        android:id="@+id/tvMainTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="DriveSafe Quiz"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1A237E" />

    <TextView
        android:id="@+id/tvMainSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="40dp"
        android:text="Select your vehicle category to start the theory test"
        android:textSize="16sp"
        android:textColor="#757575" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnCar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="🚗   Private Car Test"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3F51B5"
            android:elevation="2dp" />

        <Button
            android:id="@+id/btnTruck"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="🚚   Heavy Truck Test"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:elevation="2dp" />

        <Button
            android:id="@+id/btnMotorcycle"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="🏍️   Motorcycle Test"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#009688"
            android:elevation="2dp" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnViewHistory"
        android:layout_width="361dp"
        android:layout_height="wrap_content"
        android:text="View History" />

</LinearLayout>